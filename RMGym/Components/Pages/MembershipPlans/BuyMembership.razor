@page "/buy-membership/{PlanId:int}"

@using RMGym.Models
@using RMGym.BLL
@using System.Text.RegularExpressions

@inject MembershipPlanService MembershipPlanService
@inject AuthService AuthService
@inject MemberService MemberService
@inject MembershipSubscriptionService MembershipSubscriptionService
@inject NavigationManager Navigation

<div class="container mt-5">

    @if (plan == null)
    {
        <div class="alert alert-warning">
            Membership Plan not found.
        </div>
    }
    else
    {
        <div class="card shadow-lg">

            <div class="card-header bg-primary text-white">
                <h3>@plan.PlanName</h3>
            </div>

            <div class="card-body">

                <div class="mb-3">
                    <strong>Description</strong><br />
                    @plan.Description
                </div>

                <div class="mb-3">
                    <strong>Duration</strong><br />
                    @((int.TryParse(plan.DurationMonths, out var d)) ? $"{d} Month(s)" : plan.DurationMonths)
                </div>

                <div class="mb-3">
                    <strong>Price</strong><br />
                    ₹@plan.Price
                </div>

                <button class="btn btn-success"
                        @onclick="ConfirmPurchase">
                    Confirm Purchase
                </button>

                @if (!string.IsNullOrWhiteSpace(message))
                {
                    <div class="alert alert-info mt-3">
                        @message
                    </div>
                }

            </div>

        </div>
    }

</div>

@code {

    [Parameter]
    public int PlanId { get; set; }

    private RMGym.Models.MembershipPlan? plan;

    private string message = "";

    protected override async Task OnInitializedAsync()
    {
        plan = await MembershipPlanService.GetMembershipPlanById(PlanId);
    }

    private async Task ConfirmPurchase()
    {
        try
        {
            if (AuthService.CurrentUser == null)
            {
                message = "Please login first.";
                return;
            }

            if (plan == null)
            {
                message = "Membership plan not found.";
                return;
            }

            // Check whether the logged-in user is already a member
            var member = await MemberService.GetMemberByUserId(AuthService.CurrentUser.UserId);

            // Create member if it doesn't exist
            if (member == null)
            {
                member = new RMGym.Models.Member
                {
                    UserId = AuthService.CurrentUser.UserId,
                    FullName = AuthService.CurrentUser.FullName,
                    Email = AuthService.CurrentUser.Email,
                    PhoneNumber = "0000000000",
                    Address = "",
                    EmergencyContactNo = "",
                    AssignedTrainer = "",
                    JoinDate = DateTime.Now,
                    IsActive = true
                };

                await MemberService.AddMember(member);

                member = await MemberService.GetMemberByUserId(AuthService.CurrentUser.UserId);

                if (member == null)
                {
                    message = "Unable to create member.";
                    return;
                }
            }

            // Create subscription
            // Parse numeric months from the stored DurationMonths string (e.g. "3 Months")
            int months = 0;
            if (!int.TryParse(plan.DurationMonths, out months))
            {
                var m = Regex.Match(plan.DurationMonths ?? "", "\\d+");
                if (m.Success)
                {
                    int.TryParse(m.Value, out months);
                }
            }

            MembershipSubscription subscription = new()
            {
                MemberId = member.MembershipId,
                PlanId = plan.PlanId,
                StartDate = DateTime.Today,
                EndDate = DateTime.Today.AddMonths(months),
                AmountPaid = plan.Price,
                IsActive = true
            };

            await MembershipSubscriptionService.AddSubscription(subscription);

            Navigation.NavigateTo("/user-dashboard");
        }
        catch (Exception ex)
        {
            message = ex.Message;
        }
    }

}