@page "/edit-membership-plan/{Id:int}"

@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Forms
@using RMGym.Models
@using RMGym.BLL

@inject MembershipPlanService MembershipPlanService
@inject NavigationManager Navigation

<h3>Edit Membership Plan</h3>

@if (plan == null)
{
    <p>Loading...</p>
}
else
{
    <EditForm Model="@plan"
              OnValidSubmit="UpdatePlan">

        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="mb-3">
            <label class="form-label">Plan Name</label>
            <InputText class="form-control"
                       @bind-Value="plan.PlanName" />
        </div>

        <div class="mb-3">
            <label class="form-label">Description</label>
            <InputTextArea class="form-control"
                           rows="4"
                           @bind-Value="plan.Description" />
        </div>

        <div class="mb-3">
            <label class="form-label">Duration (Months)</label>
            <InputText class="form-control"
                       @bind-Value="plan.DurationMonths" />
        </div>

        <div class="mb-3">
            <label class="form-label">Price</label>
            <InputNumber class="form-control"
                         @bind-Value="plan.Price" />
        </div>

        <div class="mb-3">
            <label class="form-label">Status</label>

            <InputSelect class="form-control"
                         TValue="bool"
                         @bind-Value="plan.IsActive">

                <option value="true">Active</option>
                <option value="false">Inactive</option>

            </InputSelect>
        </div>

        <button type="submit" class="btn btn-primary">
            Update Plan
        </button>

        <a href="/membership-plans"
           class="btn btn-secondary ms-2">
            Cancel
        </a>

    </EditForm>
}

@code {

    [Parameter]
    public int Id { get; set; }

    private MembershipPlan? plan;

    protected override async Task OnParametersSetAsync()
    {
        plan = await MembershipPlanService.GetMembershipPlanById(Id);
    }

    private async Task UpdatePlan()
    {
        if (plan != null)
        {
            await MembershipPlanService.UpdateMembershipPlan(plan);

            Navigation.NavigateTo("/membership-plans");
        }
    }

}