@page "/profile"

@using RMGym.BLL
@inject AuthService AuthService
@inject NavigationManager Navigation

<div class="container py-5">

    <div class="card shadow border-0 rounded-4">
        <div class="card-body p-5">

            <div class="text-center mb-4">
                <img src="https://cdn-icons-png.flaticon.com/512/149/149071.png"
                     width="120"
                     class="rounded-circle border" />

                <h2 class="mt-3">@FullName</h2>

                <span class="badge bg-success">
                    @Status
                </span>
            </div>

            <hr />

            <div class="row">

                <div class="col-md-6 mb-4">
                    <h5 class="text-primary">Personal Information</h5>

                    <p>
                        <strong>Full Name:</strong>
                        @FullName
                    </p>

                    <p>
                        <strong>Email:</strong>
                        @Email
                    </p>

                    <p>
                        <strong>Role:</strong>
                        @Role
                    </p>
                </div>

                <div class="col-md-6 mb-4">
                    <h5 class="text-primary">Gym Information</h5>

                    <p>
                        <strong>Membership:</strong>
                        Not Subscribed
                    </p>

                    <p>
                        <strong>Trainer:</strong>
                        Not Assigned
                    </p>

                    <p>
                        <strong>Join Date:</strong>
                        N/A
                    </p>
                </div>

            </div>

            <div class="text-center mt-4">

                <button class="btn btn-primary me-2"
                        @onclick="EditProfile">
                    Edit Profile
                </button>

                <button class="btn btn-warning"
                        @onclick="ChangePassword">
                    Change Password
                </button>

            </div>

        </div>
    </div>

</div>

@code {

    private string FullName = "";
    private string Email = "";
    private string Role = "";
    private string Status = "";

    protected override void OnInitialized()
    {
        if (!AuthService.IsLoggedIn)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        FullName = AuthService.CurrentUser?.FullName ?? "";
        Email = AuthService.CurrentUser?.Email ?? "";
        Role = AuthService.CurrentUser?.Role ?? "";
        Status = AuthService.CurrentUser?.IsActive == true
                    ? "Active"
                    : "Inactive";
    }
    private void EditProfile()
    {
        Navigation.NavigateTo("/edit-profile");
    }

    private void ChangePassword()
    {
        Navigation.NavigateTo("/change-password");
    }
}