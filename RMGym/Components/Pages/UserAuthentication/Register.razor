@page "/user-register"

@using RMGym.Models
@using RMGym.BLL

@inject UserService UserService
@inject NavigationManager Navigation

<div class="register-wrapper">
    <div class="container">
        <div class="row justify-content-center align-items-center min-vh-100">

            <div class="col-lg-5 col-md-7">

                <div class="register-card">

                    <div class="text-center mb-4">
                        <h1 class="brand-title">RM GYM</h1>
                        <p class="brand-subtitle">
                            Create your account and begin your fitness journey
                        </p>
                    </div>

                    <EditForm Model="@user"
                              OnValidSubmit="RegisterUser"
                              FormName="RegisterForm">

                        <DataAnnotationsValidator />
                        <ValidationSummary />

                        <div class="mb-3">
                            <label class="form-label">Full Name</label>
                            <InputText class="form-control custom-input"
                                       @bind-Value="user.FullName"
                                       placeholder="Enter your full name" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Email Address</label>
                            <InputText class="form-control custom-input"
                                       @bind-Value="user.Email"
                                       placeholder="Enter your email address" />
                        </div>

                        <div class="mb-4">
                            <label class="form-label">Password</label>
                            <InputText type="password"
                                       class="form-control custom-input"
                                       @bind-Value="user.Password"
                                       placeholder="Enter your password" />
                        </div>

                        <button type="submit" class="btn register-btn w-100">
                            Create Account
                        </button>

                    </EditForm>

                    @if (!string.IsNullOrEmpty(message))
                    {
                        <div class="alert alert-success mt-3">
                            @message
                        </div>
                    }

                    <div class="text-center mt-4">
                        <span class="text-light">
                            Already have an account?
                        </span>
                        <a href="/user-login" class="login-link">
                            Sign In
                        </a>
                    </div>

                </div>

            </div>

        </div>
    </div>
</div>

<style>
    .register-wrapper {
        min-height: 100vh;
        background: linear-gradient(135deg,#0f172a,#1e3a8a,#7c3aed);
    }

    .register-card {
        background: rgba(255,255,255,0.12);
        backdrop-filter: blur(15px);
        border-radius: 24px;
        padding: 40px;
        box-shadow: 0 20px 50px rgba(0,0,0,.25);
    }

    .brand-title {
        color: white;
        font-size: 2.8rem;
        font-weight: 700;
        letter-spacing: 2px;
    }

    .brand-subtitle {
        color: rgba(255,255,255,.85);
        margin-top: 10px;
    }

    .form-label {
        color: white;
        font-weight: 600;
        margin-bottom: 8px;
    }

    .custom-input {
        height: 50px;
        border-radius: 12px;
        border: none;
        padding-left: 15px;
    }

        .custom-input:focus {
            box-shadow: 0 0 12px rgba(124,58,237,.4);
        }

    .register-btn {
        height: 52px;
        border: none;
        border-radius: 12px;
        background: linear-gradient(90deg,#2563eb,#7c3aed);
        color: white;
        font-weight: 600;
        font-size: 16px;
        transition: .3s;
    }

        .register-btn:hover {
            transform: translateY(-2px);
            opacity: .95;
        }

    .login-link {
        color: #facc15;
        font-weight: 600;
        text-decoration: none;
        margin-left: 5px;
    }

        .login-link:hover {
            text-decoration: underline;
        }

    .validation-message {
        color: #ffd54f;
    }
</style>

@code {

    private User user = new();

    private string message = string.Empty;

    private async Task RegisterUser()
    {
        try
        {
            bool emailExists = await UserService.EmailExist(user.Email);

            if (emailExists)
            {
                message = "Email already registered.";
                return;
            }

            user.Role = "User";
            user.IsActive = true;

            await UserService.RegisterUser(user);

            message = "Registration successful!";
        }
        catch (Exception ex)
        {
            message = ex.ToString();
        }
    }
}