@page "/add-member"
@rendermode InteractiveServer
@using RMGym.Models
@using RMGym.BLL
@inject MemberService MemberService
@inject NavigationManager Navigation
@using Microsoft.AspNetCore.Components.Forms

<h3>Add Member</h3>

<EditForm Model="@member"
          OnValidSubmit="SaveMember"
          FormName="AddMemberForm">

    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="mb-3">
        <label>Full Name</label>
        <InputText class="form-control" @bind-Value="member.FullName" />
    </div>

    <div class="mb-3">
        <label>Phone Number</label>
        <InputText class="form-control" @bind-Value="member.PhoneNumber" />
    </div>

    <div class="mb-3">
        <label>Email</label>
        <InputText class="form-control" @bind-Value="member.Email" />
    </div>

    <div class="mb-3">
        <label>Address</label>
        <InputText class="form-control" @bind-Value="member.Address" />
    </div>

    <div class="mb-3">
        <label>EmergencyContactNo</label>
        <InputText class="form-control" @bind-Value="member.EmergencyContactNo"/>
    </div>

    <div class="mb-3">
        <label>Join Date</label>
        <InputDate class="form-control" @bind-Value="member.JoinDate" />
    </div>

    <div class="mb-3">
        <label>Assigned Trainer</label>
        <InputText class="form-control" @bind-Value="member.AssignedTrainer" />
    </div>

    <div class="mb-3">
        <label>Status</label>
        <InputSelect class="form-control" @bind-Value="member.IsActive">
            <option value="true">Active</option>
            <option value="false">Inactive</option>
        </InputSelect>
    </div>


    <button type="submit" class="btn btn-primary">
        Save Member
    </button>
</EditForm>

@code {
    private Member member = new();

    private async Task SaveMember()
    {
        await MemberService.AddMember(member);

        Navigation.NavigateTo("/members");
    }
}