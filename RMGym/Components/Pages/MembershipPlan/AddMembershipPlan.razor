@page "/add-membership-plan"
@rendermode InteractiveServer

@using RMGym.BLL
@using Microsoft.AspNetCore.Components.Forms

@inject MembershipPlanService MembershipPlanService
@inject NavigationManager Navigation

<h3>Add Membership Plan</h3>

<EditForm Model="@plan"
          OnValidSubmit="SavePlan"
          FormName="AddMembershipPlanForm">

    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="mb-3">
        <label class="form-label">Plan Name</label>
        <InputText class="form-control"
                   @bind-Value="plan.PlanName" />
    </div>

    <div class="mb-3">
        <label class="form-label">Description</label>
        <InputTextArea class="form-control"
                       rows="4"
                       @bind-Value="plan.Description" />
    </div>

    <div class="mb-3">
        <label class="form-label">Duration (Months)</label>
        <InputText class="form-control"
                   @bind-Value="plan.DurationMonths" />
    </div>

    <div class="mb-3">
        <label class="form-label">Price</label>
        <InputNumber class="form-control"
                     @bind-Value="plan.Price" />
    </div>

    <div class="mb-3">
        <label class="form-label">Status</label>
        <InputSelect class="form-control"
                     @bind-Value="plan.IsActive">
            <option value="true">Active</option>
            <option value="false">Inactive</option>
        </InputSelect>
    </div>

    <button type="submit" class="btn btn-success">
        Save Plan
    </button>

    <a href="/membership-plans"
       class="btn btn-secondary ms-2">
        Cancel
    </a>

</EditForm>

@code {

    private RMGym.Models.MembershipPlan plan = new();

    private async Task SavePlan()
    {
        MembershipPlanService.AddMembershipPlan(plan); 
        Navigation.NavigateTo("/membership-plans");
    }

}